<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <link href='https://fonts.googleapis.com/css?family=Montserrat:400,600,700' rel='stylesheet' type='text/css' />
    <title>{{subject}}</title>
  </head>
  <body style='font-family: "Montserrat", sans-serif; background-color: #f0f4f8; color: #333; margin: 0; padding: 30px 0;'>
    <div style='max-width: 600px; margin: 0 auto; background-color: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08);'>

      <!-- Header -->
      <div style='background: linear-gradient(135deg, #0199d4 0%, #0178a8 100%); padding: 32px 36px;'>
        <h1 style='color: #fff; margin: 0; font-size: 22px; font-weight: 700; letter-spacing: -0.3px;'>{{subject}}</h1>
        <p style='color: rgba(255,255,255,0.75); margin: 8px 0 0; font-size: 13px;'>Mensaje de Metrocal</p>
      </div>

      <!-- Body -->
      <div style='padding: 36px;'>
        <div style='font-size: 15px; line-height: 1.75; color: #444; white-space: pre-line;'>{{body}}</div>
      </div>

      <!-- Divider -->
      <div style='height: 1px; background: #f0f0f0; margin: 0 36px;'></div>

      <!-- Footer -->
      <div style='padding: 24px 36px; background-color: #fafafa;'>
        <p style='margin: 0; font-size: 12px; color: #999; text-align: center;'>
          Este mensaje fue enviado automáticamente desde el sistema administrativo de Metrocal.<br/>
          Por favor no responda directamente a este correo.
        </p>
      </div>
    </div>
  </body>
</html>
